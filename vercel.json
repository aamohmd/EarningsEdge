{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/brief/(.+)", "dest": "/api/main.py" },
    { "src": "/signals/(.+)", "dest": "/api/main.py" },
    { "src": "/compare", "dest": "/api/main.py" },
    { "src": "/health", "dest": "/api/main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
