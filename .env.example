# Database (Supabase)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres"

# LLM Providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..." # Optional, recommended for fast transcript parsing (Haiku)

# Bright Data API Keys
BRIGHT_DATA_SERP_KEY="..."
BRIGHT_DATA_WEB_UNLOCKER_KEY="..."
BRIGHT_DATA_SCRAPER_KEY="..."

# Financial Data (Optional/Enhancements)
YFINANCE_API_KEY="..." # If using premium, otherwise leave blank
POLYGON_API_KEY="..."